{
  "version": 1,
  "projects": {
    "gestionmissions": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/gestionmissions",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "styles": [
              "src/styles.css"
            ],
            "polyfills": [
              "zone.js"
            ]
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "port": 4200
          },
          "configurations": {
            "development": {
              "buildTarget": "gestionmissions:build"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "defaultProject": "gestionmissions"
}